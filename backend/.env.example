# ─────────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────
# BASE DE DATOS — Railway PostgreSQL
#
# DATABASE_URL  : conexión superusuario (solo para: node scripts/migrate.js)
# APP_DATABASE_URL : conexión del rol nova_app (runtime de la app, sujeto a RLS)
#
# En desarrollo sin rol separado puedes usar DATABASE_URL para ambas.
# Formato Railway: postgresql://user:password@host:port/database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@containers-us-west-X.railway.app:5432/railway
APP_DATABASE_URL=postgresql://nova_app:CHANGE_ME@containers-us-west-X.railway.app:5432/railway

# ─────────────────────────────────────────────
# JWT
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ─────────────────────────────────────────────
# CIFRADO AES-256 para credenciales Nova
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DEBE ser exactamente 64 caracteres hexadecimales
# ─────────────────────────────────────────────
ENCRYPTION_KEY=64-caracteres-hexadecimales-aqui

# ─────────────────────────────────────────────
# NOVA-MLVM API
# ─────────────────────────────────────────────
NOVA_BASE_URL=https://mlvm.apiws.co

# ─────────────────────────────────────────────
# CORS — orígenes permitidos (separados por coma)
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://tu-app.railway.app

# ─────────────────────────────────────────────
# MODO DE DESARROLLO LOCAL (opcional)
# Si LOCAL_AUTH_BYPASS=true el login no requiere DB.
# Las transacciones no se guardan en este modo.
# Para el historial/analytics se requiere DATABASE_URL configurado.
# ─────────────────────────────────────────────
# LOCAL_AUTH_BYPASS=true
# LOCAL_AUTH_EMAIL=dev@local.test
# LOCAL_AUTH_PASSWORD=Dev12345
# LOCAL_AUTH_NAME=Usuario Local
# LOCAL_AUTH_USER_ID=local-dev-user
# LOCAL_NOVA_CLIENT_ID=tu-client-id-real-de-nova
# LOCAL_NOVA_CLIENT_SECRET=tu-client-secret-real-de-nova
